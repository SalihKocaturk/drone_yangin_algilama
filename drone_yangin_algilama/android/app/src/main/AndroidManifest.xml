<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===================== ERKEN UYARI PROTOTIPI - GEREKLI IZINLER ===================== -->

    <!-- Ekranin ustunde sefaf katman (overlay) gostermek icin (Android 6+ icin ayrica
         kullanicidan "Diger uygulamalarin uzerinde goster" izni runtime'da istenmeli) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service'i baslatip canli kalmasini saglamak icin -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14 (API 34)+ icin foreground service tipi bildirilmesi zorunlu:
         mediaProjection (ekran yakalama) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- MediaProjection ile ekran goruntusu yakalamak icin -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Bildirim gostermek icin (Android 13+ runtime izin gerektirir) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Cihaz uykuya gecsa bile servisin calismaya devam etmesi icin (opsiyonel ama onerilir) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Tello'nun Wi-Fi Access Point'ine baglanmak ve agdaki goruntuyu okumak icin -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- Servis yeniden baslatildiginda otomatik tetiklenmesi icin (opsiyonel) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:label="drone_yangin_algilama"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- ===================== FOREGROUND SERVICE TANIMI =====================
             MediaProjection + Overlay yonetimini bu servis uzerinden yapiyoruz.
             foregroundServiceType="mediaProjection" Android 14+ icin zorunludur. -->
        <service
            android:name=".OverlayDetectionService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
